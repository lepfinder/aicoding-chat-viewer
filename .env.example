# OpenAI 兼容接口（火山方舟 Coding API 等）
OPENAI_API_KEY=your-api-key-here
OPENAI_BASE_URL=https://ark.cn-beijing.volces.com/api/coding/v3
OPENAI_MODEL=doubao-seed-1-8-251228
# kimi 等思考模型建议开启，避免 content 为空
OPENAI_DISABLE_THINKING=true

# --- 路径（可选，不设置则使用下列默认值）---
# ANTIGRAVITY_DATA_DIR=~/.gemini/antigravity-ide
# ANTIGRAVITY_LEGACY_DATA_DIR=~/.gemini/antigravity
# CHAT_VIEWER_DB_PATH=data/antigravity_chats.db
# CURSOR_USER_DIR=~/Library/Application Support/Cursor/User
# CURSOR_DB_PATH=~/Library/Application Support/Cursor/User/globalStorage/state.vscdb
# CURSOR_WS_STORAGE_DIR=~/Library/Application Support/Cursor/User/workspaceStorage
# CURSOR_PROJECTS_DIR=~/.cursor/projects
# CHAT_VIEWER_HOST=127.0.0.1
# CHAT_VIEWER_PORT=8788
